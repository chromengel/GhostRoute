{
  "version": 8,
  "name": "GhostRoute Day",
  "metadata": {
    "ghostroute:note": "Offline day style. Glyphs are bundled in app assets (asset://glyphs) so labels render with zero network. __BASEMAP_URL__ is replaced at runtime with the on-device PMTiles path. Schema: OpenMapTiles (Planetiler default)."
  },
  "glyphs": "asset://glyphs/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "__BASEMAP_URL__"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#F4F1EB" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "wood", "forest"],
      "paint": { "fill-color": "#C4DEB0", "fill-opacity": 0.55 }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "meadow", "wetland"],
      "paint": { "fill-color": "#CFE6BA", "fill-opacity": 0.5 }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "residential", "suburb", "neighbourhood"],
      "paint": { "fill-color": "#ECE7DD", "fill-opacity": 0.7 }
    },
    {
      "id": "landuse-civic",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["in", "class", "hospital", "school", "university", "college"],
      "paint": { "fill-color": "#E9E2EC", "fill-opacity": 0.6 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#BFE0A8", "fill-opacity": 0.55 }
    },
    {
      "id": "park-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "park",
      "minzoom": 12,
      "paint": { "line-color": "#A6CE8C", "line-width": 1, "line-opacity": 0.6 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#A6CBE6" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#A6CBE6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.6, 18, 3]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#E6DFD2",
        "fill-outline-color": "#D8D0C0",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 14, 0.9]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "track"],
      "minzoom": 13,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.8, 18, 6]
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "pedestrian", "footway"],
      "minzoom": 15,
      "paint": {
        "line-color": "#CDBE9E",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 15, 0.6, 18, 2]
      }
    },
    {
      "id": "road-secondary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "minzoom": 9,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D8D2C4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 1.2, 18, 12]
      }
    },
    {
      "id": "road-primary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "minzoom": 8,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#E9D6AE",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.4, 18, 15]
      }
    },
    {
      "id": "road-trunk-motorway-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "trunk", "motorway"],
      "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D9BE84",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1.2, 18, 15]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "minzoom": 9,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 18, 9]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "minzoom": 8,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFF6E0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.6, 18, 12]
      }
    },
    {
      "id": "road-trunk-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "trunk", "motorway"],
      "minzoom": 5,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#F4DFB0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 18, 11]
      }
    },
    {
      "id": "boundary-admin",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 4],
      "paint": {
        "line-color": "#B6A8C4",
        "line-dasharray": [3, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.6, 12, 1.6]
      }
    },
    {
      "id": "label-road",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 18, 13],
        "symbol-spacing": 300,
        "text-max-angle": 35
      },
      "paint": {
        "text-color": "#5A5A5A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "label-water",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "minzoom": 11,
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 10, 16, 14]
      },
      "paint": {
        "text-color": "#3E6E8E",
        "text-halo-color": "#EAF3FA",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "label-place-small",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "village", "suburb", "neighbourhood", "hamlet"],
      "minzoom": 11,
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 11, 16, 15]
      },
      "paint": {
        "text-color": "#5A5A5A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "label-place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 8,
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 17]
      },
      "paint": {
        "text-color": "#3C4043",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "label-place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "minzoom": 5,
      "layout": {
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 12, 12, 20]
      },
      "paint": {
        "text-color": "#2B2D30",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 2
      }
    }
  ]
}
